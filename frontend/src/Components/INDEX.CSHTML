                <!-- FEATURE 01 -->
                <article class="feature__panel feature__panel--large vs-01 img--zoomout wow_custom">
                    <span class="feature__panel-no">FEATURE 01</span>

                    <div class="feature__panel-box">

                        <div class="feature__panel-head">
                            <h3 class="feature__panel-title">
                                地域のかかりつけ医として。親子医師が支える幅広い内科診療
                            </h3>
                        </div>

                        <div class="feature__panel-body">

                            <figure class="feature__panel-thumb">
                                <img src="~/images/feature__01.png" alt="親子医師" />
                            </figure>

                            <div class="feature__panel-text">
                                <p class="feature__panel-desc">
                                    当院で診療にあたるのは、八雲地域の医療を長く支えてきた院長と、その背中を見て医師を志した副院長という親子2代の医師。風邪や発熱といった急な不調から生活習慣病、お子様の診療まで幅広い内科領域に対応しています。
                                </p>
                            </div>

                            <div class="btn__default vs-02">
                                <a asp-controller="Home" asp-action="Doctor" class="btn__default-link">医師紹介</a>
                                <a asp-controller="Home" asp-action="Clinic" class="btn__default-link">クリニック紹介</a>
                            </div>

                        </div>
                    </div>
                </article>

                <!-- FEATURE 02 -->
                <article class="feature__panel feature__panel--large vs-02 img--zoomout wow_custom">
                    <span class="feature__panel-no">FEATURE 02</span>

                    <div class="feature__panel-box">

                        <div class="feature__panel-head">
                            <h3 class="feature__panel-title">
                                早期発見・早期治療。循環器の専門医 による質の高い医療
                            </h3>
                        </div>

                        <div class="feature__panel-body">

                            <figure class="feature__panel-thumb">
                                <img src="~/images/feature__02.png" alt="循環器" />
                            </figure>

                            <div class="feature__panel-text">
                                <p class="feature__panel-desc">
                                    当クリニックの副院長は、日本循環器学会が認定する専門医です。高性能エコー機器や24時間ホルター心電計といった高性能な検査機器を駆使し、循環器疾患の早期発見に注力。大規模病院と比肩するほどの専門的な診療提供を目指しています。
                                </p>
                            </div>

                            <div class="btn__default vs-02">
                                <a asp-controller="Home" asp-action="Doctor" class="btn__default-link">医師紹介</a>
                                <a asp-controller="Home" asp-action="Clinic" class="btn__default-link">ドクターズインタビュー</a>
                            </div>

                        </div>
                    </div>
                </article>

            </div>

            <!-- ROW 2 -->
            <div class="feature__row feature__row--secondary d-flex flex-wrap">

                <!-- FEATURE 03 -->
                <article class="feature__panel feature__panel--small vs-03 img--zoomout wow_custom">
                    <span class="feature__panel-no">FEATURE 03</span>

                    <div class="feature__panel-box">

                        <figure class="feature__panel-thumb">
                            <img src="~/images/feature__03.png" alt="訪問診療" />
                        </figure>

                        <div class="feature__panel-info">

                            <h3 class="feature__panel-title">
                                訪問診療と往診。多職種チームで支える地域の暮らし
                            </h3>

                            <p class="feature__panel-desc">
                                さまざまな事情で病院に通えない方を対象にした在宅医療も提供。医療・福祉・介護の多職種連携のもと、計画を立てて定期的に自宅等で処置を行う「訪問診療」、突発的な依頼にも対応する「往診」のどちらも承っています。
                            </p>

                        </div>

                        <div class="btn__default vs-02">
                            <a asp-controller="Home" asp-action="VisitMedicalCare" class="btn__default-link">訪問診療</a>
                            <a asp-controller="Home" asp-action="HomeCareConsultation" class="btn__default-link">訪問診療に関するご相談</a>
                        </div>

                    </div>
                </article>

                <!-- FEATURE 04 -->
                <article class="feature__panel feature__panel--small vs-04 img--zoomout wow_custom">
                    <span class="feature__panel-no">FEATURE 04</span>

                    <a asp-controller="Home" asp-action="Clinic" class="feature__panel-box">

                        <figure class="feature__panel-thumb">
                            <img src="~/images/feature__04.png" alt="24時間対応" />
                        </figure>

                        <div class="feature__panel-info">

                            <h3 class="feature__panel-title">
                                24時間つながる安心感を。機能強化型在宅療養支援診療所
                            </h3>

                            <p class="feature__panel-desc">
                                当クリニックは、機能強化型在宅療養支援診療所として夜間や休日含む24時間の連絡体制を整備。地域の基幹病院と連携しながら、緊急往診、在宅での看取り、緊急入院の対応・手配など切れ目のない医療を提供しています。
                            </p>

                        </div>

                        <div class="btn__default">
                            <p class="btn__default-link">クリニック紹介</p>
                        </div>

                    </a>
                </article>

                <!-- FEATURE 05 -->
                <article class="feature__panel feature__panel--small vs-05 img--zoomout wow_custom">
                    <span class="feature__panel-no">FEATURE 05</span>

                    <div class="feature__panel-box">

                        <figure class="feature__panel-thumb">
                            <img src="~/images/feature__05.png" alt="検査機器" />
                        </figure>

                        <div class="feature__panel-info">

                            <h3 class="feature__panel-title">
                                不調の原因を見逃さない。充実の検査機器で的確な診断を
                            </h3>

                            <p class="feature__panel-desc">
                                血液や尿を調べる検体検査、レントゲンやエコーといった画像検査、心臓の状態を調べる心電図検査など設備も充実。ほかにも睡眠時無呼吸検査や動脈硬化の検査などを実施しており、不調の原因を早期かつ的確に診断します。
                            </p>

                        </div>

                        <div class="btn__default vs-02">
                            <a asp-controller="Home" asp-action="Examinations" class="btn__default-link">各種検査</a>
                            <a asp-controller="Home" asp-action="Cardiovascular" class="btn__default-link">循環器科</a>
                        </div>

                    </div>
                </article>

            </div>

        </div>
    </div>
</div>

      {/* ===== MESSAGE ===== */}
     <div class="message space__top-01 space__bottom">
    <div class="message_section">
        <div class="message__hd">
            <div class="title__default vs-01 wow_custom">
                <h3 class="section-title-en">MESSAGE</h3>
                <p class="section-title-ja">ご挨拶</p>
            </div>
        </div>

        <div class="message__inner grid-1745">
            <div class="message__wrap">

                <div class="message__layout d-flex flex-wrap">

                    <!-- LEFT -->
                    <div class="message__col">
                        <div class="message__col-gp">

                            <div class="message__content">

                                <h4 class="message__heading wow_custom">
                                    @Model.MessageHeading
                                </h4>

                                <p class="message__desc wow_custom">
                                    @Model.MessageDescription
                                </p>

                                <div class="message__actions d-flex flex-wrap wow_custom">

                                    <a class="message__btn vs-01" href="@Url.Action("Doctor","Home")">
                                        <span class="message__btn-txt">医師紹介</span>

                                        <span class="message__btn-thumb">
                                            <img src="@Model.DoctorImage1" alt="doctor" />
                                        </span>
                                    </a>

                                    <a class="message__btn vs-02" href="@Url.Action("DoctorInterview","Home")">
                                        <span class="message__btn-txt">ドクターズインタビュー</span>

                                        <span class="message__btn-thumb">
                                            <img src="@Model.DoctorImage2" alt="doctor" />
                                        </span>
                                    </a>

                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- RIGHT -->
                    <div class="message__col">

                        <div class="message__media">

                            <img class="message__img-doctor"
                                 src="@Model.MainDoctorImage"
                                 alt="doctor" />

                            <div class="message__doctor d-flex items-center flex-wrap wow_custom">

                                <p class="message__doctor-en">
                                    @Model.DoctorNameEn
                                </p>

                                <p class="message__doctor-name">
                                    @Model.DoctorName
                                </p>

                                <p class="message__doctor-role">
                                    @Model.DoctorRole
                                </p>

                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

      {/* ===== COLUMN ===== */}
      <div class="column space__bottom">
    <div class="column__inner grid-1485">

        <div class="column__head d-flex justify-between items-end">
            <h3 class="section-title-en">COLUMN</h3>

            <div class="btn__default">
                <a class="btn__default-link hv-o wow_custom"
                   href="@Url.Action("Index","Column")">
                    もっと見る
                </a>
            </div>
        </div>

        <ul class="column__list d-flex flex-wrap wow_custom">

            @foreach (var item in Model.Columns)
            {
                <li class="column__card img--zoomout">
                    <a href="@Url.Action("Detail","Column", new { id = item.Id })"
                       class="column__link">

                        <figure class="column__thumb">
                            <img src="@item.Image" alt="@item.Title" />
                        </figure>
                    </a>

                    <div class="column__body">
                        <span class="column__meta d-flex mt-1-5 mb-1">
                            <time class="column__date">
                                @item.Date.ToString("yyyy.MM.dd")
                            </time>
                        </span>

                        <a href="@Url.Action("Detail","Column", new { id = item.Id })"
                           class="column__heading">

                            <span class="column__heading-txt">
                                @item.Title
                            </span>
                        </a>

                        <span class="column__desc">
                            @item.Description
                            <a href="@Url.Action("Detail","Column", new { id = item.Id })"
                               class="column__more">
                                more
                            </a>
                        </span>
                    </div>
                </li>
            }

        </ul>

    </div>
</div>

      {/* ===== CLINIC ===== */}
      <div id="clinic-top" class="clinic space__top-02">
    <div class="clinic__inner grid-1145">

        <div class="clinic__head">
            <div class="title__default vs-01 wow_custom">
                <h2 class="section-title-en">CLINIC INFOR</h2>
                <p class="section-title-ja">医院紹介</p>
            </div>
        </div>

        <div class="clinic__wrap">

            <div class="clinic__layout d-flex flex-wrap">

                <!-- LEFT -->
                <div class="clinic__col clinic__col--primary">

                    <table class="wow_custom">
                        <tbody class="clinic__data">

                            <tr class="clinic__row">
                                <td class="clinic__label">医院名</td>
                                <td class="clinic__value">@Model.ClinicName</td>
                            </tr>

                            <tr class="clinic__row">
                                <td class="clinic__label">診療科目</td>
                                <td class="clinic__value">@Model.Services</td>
                            </tr>

                            <tr class="clinic__row">
                                <td class="clinic__label">副院長</td>
                                <td class="clinic__value">@Model.DoctorName</td>
                            </tr>

                            <tr class="clinic__row">
                                <td class="clinic__label">住所</td>
                                <td class="clinic__value">@Model.Address</td>
                            </tr>

                            <tr class="clinic__row">
                                <td class="clinic__label">駐車場</td>
                                <td class="clinic__value">@Model.Parking</td>
                            </tr>

                            <tr class="clinic__row">
                                <td class="clinic__label">位置</td>
                                <td class="clinic__value">@Model.Location</td>
                            </tr>

                        </tbody>
                    </table>

                    <div class="clinic__actions wow_custom">
                        <div class="clinic__btn clinic__btn--primary">
                            <a class="clinic__btn-link" href="@Url.Action("FirstVisit","Home")">
                                初診の方へ
                            </a>
                        </div>

                        <div class="clinic__btn clinic__btn--secondary">
                            <a class="clinic__btn-link" href="@Url.Action("Clinic","Home")#b4">
                                アクセス・地図
                            </a>
                        </div>
                    </div>

                    <ul class="clinic__tags u-hidden-md-down wow_custom">
                        @foreach (var tag in Model.Tags)
                        {
                            <li class="clinic__tag">@tag</li>
                        }
                    </ul>

                </div>

                <!-- RIGHT -->
                <div class="clinic__col clinic__col--secondary">

                    <div class="clinic__schedule">

                        <table class="clinic__table wow_custom">
                            <tbody>

                                <tr>
                                    <th class="clinic__table-head">診療時間</th>
                                    <th>月</th>
                                    <th>火</th>
                                    <th>水</th>
                                    <th>木</th>
                                    <th>金</th>
                                    <th>土</th>
                                    <th>日</th>
                                    <th>祝</th>
                                </tr>

                                @foreach (var schedule in Model.Schedules)
                                {
                                    <tr>
                                        <td class="clinic__table-head">
                                            @schedule.Time
                                            <span class="clinic__note-small">@schedule.Label</span>
                                        </td>

                                        @foreach (var day in schedule.Days)
                                        {
                                            if (day)
                                            {
                                                <td class="is-open"></td>
                                            }
                                            else
                                            {
                                                <td class="is-close">×</td>
                                            }
                                        }
                                    </tr>
                                }

                            </tbody>
                        </table>

                        <p class="clinic__notes wow_custom">
                            @Html.Raw(Model.Notes)
                        </p>

                    </div>

                    <div class="clinic__contact d-flex justify-between wow_custom">

                        <a class="clinic__tel hv-o--01" href="tel:@Model.Phone">
                            <span class="clinic__tel-label">ご予約・お問い合わせ</span>
                            <span class="clinic__tel-number">@Model.Phone</span>
                        </a>

                    </div>

                </div>

            </div>

            <div class="clinic__map">
                <iframe src="@Model.MapEmbedUrl"
                        width="100%" style="border:0;"
                        allowfullscreen="" loading="lazy"></iframe>
            </div>

        </div>
    </div>
</div>

    </main>
  );
}

@section Scripts {
<script>
document.addEventListener("DOMContentLoaded", function () {

    const slides = document.querySelectorAll(".clinic-hero__slides li");
    let index = 0;

    if (slides.length === 0) return;

    slides[index].classList.add("active");

    setInterval(function () {
        slides[index].classList.remove("active");

        index = (index + 1) % slides.length;

        slides[index].classList.add("active");

    }, 4000);

});
</script>
}

export default HomeUI;